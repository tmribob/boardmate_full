# Скопируйте в .env и измените секреты перед запуском:
#   copy .env.example .env

APP_PORT=80

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=boardmate

MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=password

DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=boardmate
DB_HOST=db
DB_PORT=5432

SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

MINIO_ENDPOINT=minio:9000
MINIO_EXTERNAL_URL=http://localhost:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=password

SITE_DOMAIN=http://localhost
DICEBEAR_API_URL=https://api.dicebear.com/7.x/pixel-art/svg

# true — создать таблицы при первом старте backend
INIT_DB=true

# URL API для сборки frontend (через reverse proxy)
REACT_APP_API_URL=/api
